#
# BackupPilot .env example
#
# Copy this file to `.env` and fill in the values for your environment.
# When you run `backup-pilot` directly on your host, BackupPilot will
# automatically load variables from `.env` in the current working directory.
#

# ---------------------------------------------------------------------------
# Encryption
# ---------------------------------------------------------------------------

# BACKUP_PILOT_ENCRYPTION_KEY should be a base64-encoded Fernet key.
# Generate one with Python, for example:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#
BACKUP_PILOT_ENCRYPTION_KEY=base64-encoded-fernet-key-here

# ---------------------------------------------------------------------------
# Database credentials (examples)
# ---------------------------------------------------------------------------

# Used in config files (e.g. backup_pilot.yaml)
MYSQL_USERNAME=root
MYSQL_PASSWORD=password
MYSQL_DATABASE=test_db
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306

# ---------------------------------------------------------------------------
# Notifications
# ---------------------------------------------------------------------------

# Slack webhook URL for notifications (optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# Email notification settings (optional)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your-smtp-username
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=backup-pilot@example.com
SMTP_TO=ops@example.com
# ---------------------------------------------------------------------------
# Cloud storage credentials
# ---------------------------------------------------------------------------

#AWS S3 (used by the S3 storage backend)
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_DEFAULT_REGION=us-east-1
AWS_BACKUP_BUCKET=amzn-s3-backup-name-113200191112-eu-central-1-an
AWS_BACKUP_PREFIX=path/to/backup


# Google Cloud Storage
# GCP_SERVICE_ACCOUNT_JSON=/path/to/service-account.json

# Azure Blob Storage
# AZURE_STORAGE_CONNECTION_STRING=your-azure-storage-connection-string

